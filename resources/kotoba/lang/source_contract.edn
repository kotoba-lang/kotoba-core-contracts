{:schema "kotoba.lang.source-contract.v0"
 :owner "kotoba/lang"
 :canonical-format :edn
 :authority "kotoba-lang/kotoba-core-contracts"
 :source-kinds {:kotoba {:extensions [".kotoba"]
                         :reader-target :kotoba
                         :reader-targets [:kotoba]
                         :canonical? true
                         :safe-gate-required? true}
                :clj {:extensions [".clj"]
                      :reader-target :clj
                      :canonical? false
                      :safe-gate-required? true}
                :cljk {:extensions [".cljk"]
                       :reader-target :kotoba
                       :canonical? false
                       :kotoba? true
                       :safe-gate-required? true}
                :cljc {:extensions [".cljc"]
                       :reader-target :kotoba
                       :reader-targets [:kotoba :clj :cljs]
                       :canonical? false
                       :portable? true
                       :safe-gate-required? true}
                :cljs {:extensions [".cljs"]
                       :reader-target :cljs
                       :canonical? false
                       :safe-gate-required? true}
                :edn {:extensions [".edn"]
                      :reader-target :edn
                      :canonical? false
                      :data? true
                      :safe-gate-required? false}}
 :namespace-resolution {:kotoba [".kotoba" ".cljc" ".cljk" ".clj" ".cljs"]
                        :clj [".cljc" ".clj" ".cljk" ".kotoba" ".cljs"]
                        :cljs [".kotoba" ".cljc" ".cljs" ".cljk" ".clj"]}
 :default-reader-target :kotoba
 :dispatch-policy {:launcher "classify source path and delegate to CLJC authority"
                   :eval "compile-and-run through source contract, not unrestricted host eval"
                   :cljc "evaluate with explicit reader target; default target is :kotoba"
                   :cljk "CLJ Kotoba source compiled by the Kotoba/Kototama compiler"
                   :web ".kotoba uses the Kotoba frontend and checked KIR -> kotoba-script for web output; .cljs remains ClojureScript"
                   :safety "all executable source kinds pass safe analyzer facts and capability policy"}}
