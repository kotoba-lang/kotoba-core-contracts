{:schema "kotoba.runtime.capability-contract.v0"
 :owner "kotoba/runtime"
 :canonical-format :edn
 :authority "kotoba-lang/kotoba-core-contracts"
 :capability-ids {"ledger/append" 201
                  "fs/app-data" 202
                  "notify/show" 203
                  "clipboard/text" 204
                  "http/fetch" 205
                  "keychain/text" 206
                  "contacts/read" 207
                  "calendar/read" 208
                  "graph/kotoba" 209
                  "log/write" 210
                  "clock/monotonic" 211
                  "random/bytes" 212
                  "topic/publish" 213
                  "topic/subscribe" 214
                  "pci/config" 215
                  "dma/map" 216
                  "irq/subscribe" 217
                  "mmio/map" 218
                  ;; kotoba-lang/kototama's actor:host ABI (kototama.contract
                  ;; / kototama.tender, ADR-2607062330/2607062400) -- module
                  ;; "kotoba", same host as everything above, so a guest can
                  ;; freely mix these with the kernel-capability imports
                  ;; already registered.
                  "identity/keypair" 219
                  "identity/sign" 220
                  "identity/verify" 221
                  "hash/sha256" 222
                  "http/post" 223
                  "log/read" 224
                  ;; `llm-infer` -- kototama.tender's Anthropic Messages API
                  ;; call (ADR-2607062330's llm-infer addendum). Same module
                  ;; "kotoba" as everything above.
                  "llm/infer" 225
                  ;; `gpu-clear` -- ADR-2607078000 Track B Phase 0 spike: the
                  ;; first `kami:engine`-independent GPU host-import, proving
                  ;; a guest-driven WebGPU call is possible over a synchronous
                  ;; Wasm host-import (the browser host does one-time async
                  ;; device/adapter setup BEFORE the guest runs; every
                  ;; per-frame call after that, including this one, is
                  ;; genuinely synchronous per the WebGPU spec). Same module
                  ;; "kotoba" as everything above.
                  "gpu/clear" 226
                  ;; Track B Phase 1 (ADR-2607078000): real f32 host-imports
                  ;; (kotoba-lang/kotoba now supports :f32 params/results,
                  ;; ADR-2607078000 Track B Phase 1's f32-compiler-support
                  ;; commit) for orbital math (cos/sin) and the render-guest
                  ;; loop (gpu-set-position/gpu-draw-frame). Same module
                  ;; "kotoba" as everything above.
                  "math/cos" 227
                  "math/sin" 228
                  "gpu/set-position" 229
                  "gpu/draw-frame" 230
                  ;; ADR-2607078000 Track B Phase 1 follow-up: animation +
                  ;; galactic-frame toggle. `now-days` lets the guest read a
                  ;; host-owned, wrapped simulated day count instead of a
                  ;; fixed t (the host advances/wraps it every
                  ;; requestAnimationFrame tick and just calls the guest's
                  ;; 0-arg `main` again -- no guest-side loop or wasm export
                  ;; beyond `main` needed). `galactic-frame?` lets the guest
                  ;; read a host-owned boolean (a page checkbox) to decide
                  ;; whether to apply the tilt+forward-drift transform.
                  "time/now-days" 231
                  "render/galactic-frame" 232
                  ;; `kami-*` -- a minimal game-engine ECS surface (entity
                  ;; spawn/despawn, position/velocity, tag queries, input
                  ;; axis, seeded rand), the kami:engine vocabulary exposed
                  ;; through THIS contract's single (module "kotoba") ABI so
                  ;; a `.kotoba` guest can drive real game logic. Same
                  ;; "guest computes, host executes" split as gpu-set-
                  ;; position above: the host owns all entity state and
                  ;; fixed-step integration, advances the tick counter, and
                  ;; calls the guest's 0-arg `main` once per tick (no
                  ;; guest-side loop); batch ops (move-tagged-toward!/
                  ;; despawn-within!) stand in for per-entity iteration the
                  ;; language deliberately doesn't have. One shared
                  ;; capability for the whole family, like "graph/kotoba"
                  ;; covering the kgraph-* quartet.
                  "kami/engine" 233
                  ;; ADR-2607140600 Phase 3a device-capability bridge (iPhone
                  ;; sensing for the indoor floorplan-lab): 4 read-only, no
                  ;; network-egress, individually-metered/gateable
                  ;; capabilities, registered through the SAME pipeline
                  ;; ADR-2607100030 established (kotoba-core-contracts
                  ;; capability id -> kotoba-lang effect-for-kind -> kotoba
                  ;; runtime op->kind/guarded-host-functions). Real hardware
                  ;; access (CoreMotion/CoreBluetooth/AVAudioEngine) is
                  ;; explicitly OUT of this ADR's scope -- these ids only
                  ;; make the capabilities nameable/gateable from `.kotoba`
                  ;; source and back a deterministic stub host, same as
                  ;; aiueos's device-access quartet (ADR-2607030900).
                  "motion/read" 234
                  "audio/io" 235
                  "ble/scan" 236
                  "wifi/info" 237}
 :special-forms #{do let if quote def defn ns}
 :host-import-order [has-capability?
                     notify-show
                     clipboard-read
                     clipboard-write
                     clipboard-write-str
                     http-fetch
                     keychain-read
                     keychain-write
                     fs-read
                     fs-write
                     host-i64-roundtrip
                     kgraph-assert!
                     kgraph-retract!
                     kgraph-get-objects
                     kgraph-query
                     log-write
                     clock-monotonic
                     random-bytes
                     topic-publish
                     topic-poll
                     topic-take
                     topic-count
                     pci-config
                     dma-map
                     irq-subscribe
                     mmio-map
                     gen-keypair
                     sign
                     verify
                     sha256-hex
                     http-post
                     log-read
                     llm-infer
                     gpu-clear
                     cos
                     sin
                     gpu-set-position
                     gpu-draw-frame
                     now-days
                     galactic-frame?
                     kami-tick-n
                     kami-spawn
                     kami-despawn
                     kami-set-position!
                     kami-set-velocity!
                     kami-get-x
                     kami-get-y
                     kami-count-tagged
                     kami-nearest-tagged
                     kami-move-tagged-toward!
                     kami-despawn-within!
                     kami-axis
                     kami-rand
                     motion-read
                     audio-play
                     audio-record
                     ble-scan
                     wifi-info]
 :host-imports {has-capability? {:module "kotoba"
                                 :field "has_capability"
                                 :params [:i32]
                                 :result :i32}
                notify-show {:module "kotoba"
                             :field "notify_show"
                             :capability "notify/show"
                             :params [:i32]
                             :result :i32}
                clipboard-read {:module "kotoba"
                                :field "clipboard_read"
                                :capability "clipboard/text"
                                :params [:i32 :i32]
                                :result :i32}
                clipboard-write {:module "kotoba"
                                 :field "clipboard_write"
                                 :capability "clipboard/text"
                                 :params [:i32 :i32]
                                 :result :i32}
                clipboard-write-str {:module "kotoba"
                                     :field "clipboard_write_str"
                                     :capability "clipboard/text"
                                     :params [:i32 :i32]
                                     :result :i32}
                http-fetch {:module "kotoba"
                            :field "http_fetch"
                            :capability "http/fetch"
                            :params [:i32 :i32 :i32 :i32]
                            :result :i32}
                keychain-read {:module "kotoba"
                               :field "keychain_read"
                               :capability "keychain/text"
                               :params [:i32 :i32 :i32 :i32]
                               :result :i32}
                keychain-write {:module "kotoba"
                                :field "keychain_write"
                                :capability "keychain/text"
                                :params [:i32 :i32 :i32 :i32]
                                :result :i32}
                fs-read {:module "kotoba"
                         :field "fs_read"
                         :capability "fs/app-data"
                         :params [:i32 :i32 :i32 :i32]
                         :result :i32}
                fs-write {:module "kotoba"
                          :field "fs_write"
                          :capability "fs/app-data"
                          :params [:i32 :i32 :i32 :i32]
                          :result :i32}
                host-i64-roundtrip {:module "kotoba"
                                    :field "host_i64_roundtrip"
                                    :capability "ledger/append"
                                    :params [:i64]
                                    :result :i64}
                kgraph-assert! {:module "kotoba"
                                :field "kgraph_assert"
                                :capability "graph/kotoba"
                                :params [:i32 :i32]
                                :result :i32}
                kgraph-retract! {:module "kotoba"
                                 :field "kgraph_retract"
                                 :capability "graph/kotoba"
                                 :params [:i32 :i32]
                                 :result :i32}
                kgraph-get-objects {:module "kotoba"
                                    :field "kgraph_get_objects"
                                    :capability "graph/kotoba"
                                    :params [:i32 :i32 :i32 :i32]
                                    :result :i32}
                kgraph-query {:module "kotoba"
                              :field "kgraph_query"
                              :capability "graph/kotoba"
                              :params [:i32 :i32 :i32 :i32]
                              :result :i32}
                log-write {:module "kotoba"
                           :field "log_write"
                           :capability "log/write"
                           :params [:i32 :i32]
                           :result :i32}
                clock-monotonic {:module "kotoba"
                                 :field "clock_monotonic"
                                 :capability "clock/monotonic"
                                 :params []
                                 :result :i64}
                random-bytes {:module "kotoba"
                              :field "random_bytes"
                              :capability "random/bytes"
                              :params [:i32 :i32]
                              :result :i32}
                topic-publish {:module "kotoba"
                               :field "topic_publish"
                               :capability "topic/publish"
                               :params [:i32 :i64]
                               :result :i32}
                topic-poll {:module "kotoba"
                            :field "topic_poll"
                            :capability "topic/subscribe"
                            :params [:i32]
                            :result :i64}
                topic-take {:module "kotoba"
                            :field "topic_take"
                            :capability "topic/subscribe"
                            :params [:i32]
                            :result :i64}
                topic-count {:module "kotoba"
                             :field "topic_count"
                             :capability "topic/subscribe"
                             :params [:i32]
                             :result :i64}
                pci-config {:module "kotoba"
                            :field "pci_config"
                            :capability "pci/config"
                            :params [:i32 :i32]
                            :result :i32}
                dma-map {:module "kotoba"
                         :field "dma_map"
                         :capability "dma/map"
                         :params [:i32 :i32]
                         :result :i64}
                irq-subscribe {:module "kotoba"
                               :field "irq_subscribe"
                               :capability "irq/subscribe"
                               :params [:i32]
                               :result :i64}
                mmio-map {:module "kotoba"
                          :field "mmio_map"
                          :capability "mmio/map"
                          :params [:i64 :i32]
                          :result :i64}
                gen-keypair {:module "kotoba"
                             :field "gen_keypair"
                             :capability "identity/keypair"
                             :params [:i32 :i32]
                             :result :i32}
                sign {:module "kotoba"
                      :field "sign"
                      :capability "identity/sign"
                      :params [:i32 :i32 :i32 :i32 :i32]
                      :result :i32}
                verify {:module "kotoba"
                        :field "verify"
                        :capability "identity/verify"
                        :params [:i32 :i32 :i32 :i32 :i32 :i32]
                        :result :i32}
                sha256-hex {:module "kotoba"
                            :field "sha256_hex"
                            :capability "hash/sha256"
                            :params [:i32 :i32 :i32 :i32]
                            :result :i32}
                http-post {:module "kotoba"
                           :field "http_post"
                           :capability "http/post"
                           :params [:i32 :i32 :i32 :i32 :i32 :i32]
                           :result :i32}
                log-read {:module "kotoba"
                          :field "log_read"
                          :capability "log/read"
                          :params [:i32 :i32]
                          :result :i32}
                llm-infer {:module "kotoba"
                           :field "llm_infer"
                           :capability "llm/infer"
                           :params [:i32 :i32 :i32 :i32]
                           :result :i32}
                ;; gpu-clear(rgba8: i32) -> 0|-1. `rgba8` is a packed 0xRRGGBBAA
                ;; 32-bit color; the browser host clears the (host-owned,
                ;; pre-created before the guest ever runs) WebGPU canvas to
                ;; that color via a synchronous render-pass + queue.submit.
                gpu-clear {:module "kotoba"
                           :field "gpu_clear"
                           :capability "gpu/clear"
                           :params [:i32]
                           :result :i32}
                ;; cos/sin(radians: f32) -> f32. Real f32 in/out (not a
                ;; fixed-point-i64 workaround) -- kotoba-lang/kotoba's
                ;; compiler now supports :f32 host-import params/results
                ;; natively (ADR-2607078000 Track B Phase 1).
                cos {:module "kotoba"
                     :field "cos"
                     :capability "math/cos"
                     :params [:f32]
                     :result :f32}
                sin {:module "kotoba"
                     :field "sin"
                     :capability "math/sin"
                     :params [:f32]
                     :result :f32}
                ;; gpu-set-position(body-id, x, y, z) -> 0|-1. Host stores
                ;; the position for that instance; the guest computes
                ;; positions (via cos/sin orbital math) and calls this once
                ;; per body per frame, then gpu-draw-frame issues the actual
                ;; draw calls using every stored position. Deliberately
                ;; scalar-only (not a guest-constructed matrix): kotoba-lang/
                ;; kotoba has no vector/matrix type or loops-beyond-recursion
                ;; yet, so the "guest computes, host renders" split keeps
                ;; matrix/pipeline/camera mechanics host-side while the guest
                ;; still genuinely drives what gets drawn where.
                gpu-set-position {:module "kotoba"
                                  :field "gpu_set_position"
                                  :capability "gpu/set-position"
                                  :params [:i32 :f32 :f32 :f32]
                                  :result :i32}
                ;; gpu-draw-frame() -> 0|-1. Synchronous (same
                ;; createCommandEncoder -> beginRenderPass -> ... ->
                ;; queue.submit sequence gpu-clear already proved works from
                ;; a sync host-import).
                gpu-draw-frame {:module "kotoba"
                                :field "gpu_draw_frame"
                                :capability "gpu/draw-frame"
                                :params []
                                :result :i32}
                ;; now-days() -> f32. The host's current simulated day count
                ;; (wrapped to a bounded window so a guest computing
                ;; positions from it never drifts out of camera frustum) --
                ;; the host recomputes this from wall-clock time once per
                ;; requestAnimationFrame tick, before calling `main` again.
                ;; No guest-side clock/loop needed.
                now-days {:module "kotoba"
                          :field "now_days"
                          :capability "time/now-days"
                          :params []
                          :result :f32}
                ;; galactic-frame?() -> 0|1. Host-owned view toggle (a page
                ;; checkbox): 1 selects the tilt+forward-drift ("helix")
                ;; transform, 0 the flat heliocentric view. A wasm i32 is
                ;; directly usable as an `if` condition (nonzero = true),
                ;; so the guest can branch on this value with no additional
                ;; boolean-decoding step.
                galactic-frame? {:module "kotoba"
                                 :field "galactic_frame"
                                 :capability "render/galactic-frame"
                                 :params []
                                 :result :i32}
                ;; kami-* game-engine ECS surface ("kami/engine" capability
                ;; note above). Tags/axis names are (ptr,len) UTF-8 string
                ;; arguments, same memory ABI as kgraph-*/http-*; positions/
                ;; velocities/speeds/radii are :f32 scalars (gpu-set-position
                ;; precedent); entity ids are :i32 handles, -1 = none/error.
                ;; kami-tick-n() -> the host's tick counter (advanced by the
                ;; host once per fixed step, before it calls `main` again).
                kami-tick-n {:module "kotoba"
                             :field "kami_tick_n"
                             :capability "kami/engine"
                             :params []
                             :result :i32}
                ;; kami-spawn(tag-ptr, tag-len) -> new entity id at (0,0).
                kami-spawn {:module "kotoba"
                            :field "kami_spawn"
                            :capability "kami/engine"
                            :params [:i32 :i32]
                            :result :i32}
                ;; kami-despawn(eid) -> 0|-1.
                kami-despawn {:module "kotoba"
                              :field "kami_despawn"
                              :capability "kami/engine"
                              :params [:i32]
                              :result :i32}
                ;; kami-set-position!(eid, x, y) -> 0|-1.
                kami-set-position! {:module "kotoba"
                                    :field "kami_set_position"
                                    :capability "kami/engine"
                                    :params [:i32 :f32 :f32]
                                    :result :i32}
                ;; kami-set-velocity!(eid, vx, vy) -> 0|-1 (units/second;
                ;; the host integrates pos += vel * dt each fixed step).
                kami-set-velocity! {:module "kotoba"
                                    :field "kami_set_velocity"
                                    :capability "kami/engine"
                                    :params [:i32 :f32 :f32]
                                    :result :i32}
                ;; kami-get-x(eid)/kami-get-y(eid) -> the entity's current
                ;; position component (0.0 for an unknown id -- the guest
                ;; can pre-check with kami-nearest-tagged/count-tagged).
                kami-get-x {:module "kotoba"
                            :field "kami_get_x"
                            :capability "kami/engine"
                            :params [:i32]
                            :result :f32}
                kami-get-y {:module "kotoba"
                            :field "kami_get_y"
                            :capability "kami/engine"
                            :params [:i32]
                            :result :f32}
                ;; kami-count-tagged(tag-ptr, tag-len) -> live entity count.
                kami-count-tagged {:module "kotoba"
                                   :field "kami_count_tagged"
                                   :capability "kami/engine"
                                   :params [:i32 :i32]
                                   :result :i32}
                ;; kami-nearest-tagged(tag-ptr, tag-len, x, y, max-dist)
                ;; -> nearest tagged entity id within max-dist, or -1.
                kami-nearest-tagged {:module "kotoba"
                                     :field "kami_nearest_tagged"
                                     :capability "kami/engine"
                                     :params [:i32 :i32 :f32 :f32 :f32]
                                     :result :i32}
                ;; kami-move-tagged-toward!(tag-ptr, tag-len, x, y, speed)
                ;; -> count of entities whose velocity was pointed at (x,y)
                ;; at `speed`. Batch op: per-entity iteration stays host-
                ;; side because the language has no loops beyond recursion.
                kami-move-tagged-toward! {:module "kotoba"
                                          :field "kami_move_tagged_toward"
                                          :capability "kami/engine"
                                          :params [:i32 :i32 :f32 :f32 :f32]
                                          :result :i32}
                ;; kami-despawn-within!(tag-ptr, tag-len, x, y, radius)
                ;; -> count of tagged entities despawned within radius.
                kami-despawn-within! {:module "kotoba"
                                      :field "kami_despawn_within"
                                      :capability "kami/engine"
                                      :params [:i32 :i32 :f32 :f32 :f32]
                                      :result :i32}
                ;; kami-axis(name-ptr, name-len) -> host-owned input axis
                ;; value in [-1.0, 1.0] (0.0 when unset), e.g. "MoveX".
                kami-axis {:module "kotoba"
                           :field "kami_axis"
                           :capability "kami/engine"
                           :params [:i32 :i32]
                           :result :f32}
                ;; kami-rand(n) -> uniform i32 in [0, n) from the host's
                ;; SEEDED xorshift64 stream (deterministic replay -- same
                ;; seed, same game; kami-engine-host.js precedent), never
                ;; the OS RNG (that's random-bytes' job).
                kami-rand {:module "kotoba"
                           :field "kami_rand"
                           :capability "kami/engine"
                           :params [:i32]
                           :result :i32}
                ;; ADR-2607140600 Phase 3a device-capability bridge -- 4
                ;; read-only iPhone sensing capabilities for the indoor
                ;; floorplan-lab. Same (out-ptr, out-cap) -> written-count-
                ;; or-(-1)-on-overflow memory ABI log-read/fs-read already
                ;; use (kotoba.wasm-exec/write-bytes!), so a guest that
                ;; doesn't yet know the byte layout still gets a bounded,
                ;; safe write instead of an unbounded one. Every op here is
                ;; backed by a deterministic stub host in kotoba (no real
                ;; CoreMotion/CoreBluetooth/AVAudioEngine access -- that
                ;; native shim is explicitly out of this ADR's scope, same
                ;; boundary aiueos draws around its device-access quartet).
                ;;
                ;; motion-read(out-ptr, out-cap) -> count of i32/f32 fixed-
                ;; point samples written (accel x/y/z, gyro x/y/z, mag
                ;; x/y/z = 9 values), or -1 if out-cap is too small. The
                ;; stub always returns 0 (no driver injected).
                motion-read {:module "kotoba"
                             :field "motion_read"
                             :capability "motion/read"
                             :params [:i32 :i32]
                             :result :i32}
                ;; audio-play(freq-hz, duration-ms) -> 0 on success, -1 on
                ;; failure. The stub always returns -1 (no driver injected,
                ;; nothing was actually played).
                audio-play {:module "kotoba"
                            :field "audio_play"
                            :capability "audio/io"
                            :params [:i32 :i32]
                            :result :i32}
                ;; audio-record(duration-ms, out-ptr, out-cap) -> count of
                ;; fixed-point PCM samples written, or -1 if out-cap is too
                ;; small. The stub always returns 0 (no driver injected).
                audio-record {:module "kotoba"
                              :field "audio_record"
                              :capability "audio/io"
                              :params [:i32 :i32 :i32]
                              :result :i32}
                ;; ble-scan(duration-ms, out-ptr, out-cap) -> count of
                ;; detected peripherals written as {id, rssi} pairs, or -1
                ;; if out-cap is too small. The stub always returns 0 (no
                ;; driver injected, no peripherals found).
                ble-scan {:module "kotoba"
                          :field "ble_scan"
                          :capability "ble/scan"
                          :params [:i32 :i32 :i32]
                          :result :i32}
                ;; wifi-info(out-ptr, out-cap) -> 0 = info unavailable
                ;; (the iOS-constrained default -- no raw RSSI scan without
                ;; special entitlements), 1 = info written to (out-ptr,
                ;; out-cap). The stub always returns 0.
                wifi-info {:module "kotoba"
                           :field "wifi_info"
                           :capability "wifi/info"
                           :params [:i32 :i32]
                           :result :i32}}}
